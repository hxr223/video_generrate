APP_NAME=Video Generation Platform
APP_ENV=local
LOG_LEVEL=INFO

ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDANCE_MODEL=doubao-seedance-1-0-pro-250528
SEEDANCE_API_BASE_URL=https://operator.las.cn-beijing.volces.com/api/v1
SEEDANCE_SUBMIT_PATH=/contents/generations/tasks
SEEDANCE_QUERY_PATH_TEMPLATE=/contents/generations/tasks/{task_id}
SEEDANCE_POLL_INTERVAL_SECONDS=10
SEEDANCE_MAX_POLL_ATTEMPTS=90
SEEDREAM_MODEL=doubao-seedream-4-5-251128
SEEDREAM_API_BASE_URL=https://operator.las.cn-beijing.volces.com/api/v1
SEEDREAM_SUBMIT_PATH=/images/generations
SEEDREAM_SIZE=1024x1024

DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/video_platform
REDIS_URL=redis://localhost:6379/0

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=video-platform
MINIO_REGION=us-east-1

OBJECT_STORAGE_PUBLIC_BASE_URL=http://localhost:9000/video-platform

LOCAL_RENDER_DIR=tmp/renders
